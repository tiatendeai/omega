# Session atomic data (never commit sensitive session data)
/sessions/*
!/sessions/.gitkeep

# Environment variables and secrets
.env
.env.local
.env.*.local
*.env
secrets.json
credentials.json
config/secrets.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
.DS_Store.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Node.js
node_modules/
npm-debug.log
yarn-error.log
coverage/
.nyc_output/

# Build outputs
dist/
build/
*.min.js
*.min.css

# Database
*.sqlite
*.db
db/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Backup files
*.bak
*.backup

# API keys and tokens
*.key
*.pem
*.crt
*.p12

# Runner reports
reports/

# Session history archive (auto-generated)
sessions/history/*.json

# Local configs with credentials
config/local.json
config/local.*.json
